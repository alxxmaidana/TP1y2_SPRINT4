<a href="/api/heroes" class="mb-4"> <- Volver al inicio</a>

        <div class="form-container">
            <h2 class="form-title">Buscar superhéroes</h2>
            <p class="form-hint">Busque superhéroes por atributo y valor</p>

            <form id="form-search" action="/api/heroes/buscar" method="GET" autocomplete="off">
                <div class="form-search">
                    <div class="search-select mt-2">
                        <label for="atribute-select">
                            Seleccione el atributo
                        </label>
                        <select name="atributo" id="select-attribute">
                            <option hidden value="none" aria-checked="">Seleccionar atributo</option>
                            <option value="nombreSuperheroe">Nombre superhéroe</option>
                            <option value="nombreReal">Nombre real</option>
                            <option value="edad">Edad</option>
                            <option value="planetaOrigen">Planeta de origen</option>
                            <option value="debilidad">Debilidad</option>
                            <option value="poderes">Poderes</option>
                            <option value="aliados">Aliados</option>
                            <option value="enemigos">Enemigos</option>
                        </select>
                    </div>
                    <div class="search-input">
                        <label for="attribute-value">Ingrese el valor</label>
                        <input id="attribute-value" name="valor" type="text" value="<%= valor %>">
                    </div>
                    <div>
                        <button id="btn-search" type="submit" class="btn btn-primary">Buscar</button>
                    </div>
                </div>
                <small>Si seleccionó poderes, aliados o enemigos. Separe por comas los valores que desee buscar</small>
            </form>

            <a href="/api/heroes" class="mb-4"> <- Volver al inicio</a>


                    <h3 class="text-xl text-center my-6 mb-4">Resultado de la búsqueda</h3>

                    <div class="search-result mt-8 ">

                        <div id="not-found-message" class="w-full nt-message 
                            <% if (atributo && valor) { %>
                                <%  total > 0 ? "hidden" : "flex" %>
                            <% } %> 
                                mb-2">
                            <span>
                                No se encontraron Superhéroes con los valores especificados
                            </span>
                        </div>

                        <% if (atributo && valor) { %>
                            <% if (total> 0) {%>
                                <div class="cards-grid">
                                    <% superheroes.forEach(heroe => { %>
                                        <%- include("partials/superheroCards", { heroe }) %>
                                    <% }) %>
                                </div>
                            <% } %>
                        <% } %>
                    </div>
        </div>



