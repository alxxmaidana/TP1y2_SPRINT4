<style>
    fieldset {
        border: 1px solid #262626;
        border-radius: 0.75rem;
        padding: .7rem 1rem;
        margin-bottom: .75rem;
    }

    legend {
        padding: 0 0.5rem;
        color: #60a5fa;
        font-weight: 600;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .field {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    label {
        margin-top: .5rem;
        font-size: 0.85rem;
        color: #9ca3af;
    }

    input {
        background: #0f0f0f;
        border: 1px solid #262626;
        padding: 0.5rem;
        border-radius: 0.4rem;
        color: white;
        font-size: 0.9rem;
        transition: 0.2s;
    }

    input:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 6px rgba(37, 99, 235, 0.5);
    }

    small {
        font-size: 0.7rem;
        color: #6b7280;
    }
</style>

<!-- IDENTIDAD -->
<fieldset>
    <legend>Identidad</legend>
    <div class="grid-2">
        <div class="field">
            <label>Nombre de superhéroe <span class="req">*</span></label>
            <input type="text" name="nombreSuperheroe" value="<%= superheroe.nombreSuperheroe %>">
        </div>

        <div class="field">
            <label>Nombre real <span class="req">*</span></label>
            <input type="text" name="nombreReal" value="<%= superheroe.nombreReal %>">
        </div>
    </div>

    <div class="grid-2">
        <div class="field">
            <label>Edad <span class="req">*</span></label>
            <input type="number" name="edad" value="<%= superheroe.edad %>">
        </div>

        <div class="field">
            <label>Planeta</label>
            <input type="text" name="planetaOrigen" value="<%= superheroe.planetaOrigen %>">
        </div>
    </div>

    <div class="field">
        <label>Creador</label>
        <input type="text" name="creador" value="<%= superheroe.creador %>">
    </div>
</fieldset>

<!-- HABILIDADES -->
<fieldset>
    <legend>Habilidades</legend>

    <div class="field">
        <label>Debilidad</label>
        <input type="text" name="debilidad" value="<%= superheroe.debilidad %>">
    </div>

    <div class="field">
        <label>Poderes <span class="req">*</span></label>
        <input type="text" name="poderes" value="<%= superheroe.poderes %>">
        <small>Separar con comas</small>
    </div>
</fieldset>

<!-- RELACIONES -->
<fieldset>
    <legend>Relaciones</legend>

    <div class="field">
        <label>Aliados</label>
        <input type="text" name="aliados" value="<%= superheroe.aliados %>">
        <small>Separar por comas</small>
    </div>

    <div class="field">
        <label>Enemigos</label>
        <input type="text" name="enemigos" value="<%= superheroe.enemigos %>">
        <small>Separar por comas</small>
    </div>
</fieldset>