<h2 class="text-2xl font-bold mb-6 text-center">Lista de Superhéroes</h2>

<div class="cards-grid">

    <% superheroes.forEach(heroe=> { %> <%- include("./partials/superheroCards", { heroe }) %>
            <% }); %>


                <script>
                    async function eliminarSuperheroe(id) {
                        const confirmar = confirm("¿Está suguro de eliminar este superhéroe? Esta acción no se puede deshacer.");

                        if (confirmar) {
                            try {
                                const response = await fetch(`/api/heroes/${id}`, { method: "DELETE" })

                                if (response.ok) {
                                    window.location.reload();
                                }
                            } catch {
                                const error = await response.json();
                                alert("Ocurrió un error inesperado.");
                                console.error("Error al eliminar el superhéroe", error.message);
                            }
                        }
                    }
                </script>
</div>