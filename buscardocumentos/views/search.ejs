<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>Búsqueda de Documentos</title>
  <style>
    body {
      font-family: sans-serif;
      max-width: 700px;
      margin: 40px auto;
      padding: 0 20px;
    }

    input[type="text"] {
      width: 70%;
      padding: 8px;
      font-size: 1rem;
    }

    button {
      padding: 8px 16px;
      font-size: 1rem;
      cursor: pointer;
    }

    .result {
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 12px;
      margin-top: 12px;
    }

    .result h3 {
      margin: 0 0 6px;
    }

    .meta {
      color: #666;
      font-size: 0.875rem;
    }

    .empty {
      color: #999;
      margin-top: 20px;
    }
  </style>
</head>

<body>

  <h1>Búsqueda de Documentos</h1>

  <!-- Formulario de búsqueda -->
  <form action="/search" method="GET">
    <input type="text" name="q" placeholder="Buscar por título, categoría o autor..." value="<%= query %>" />
    <button type="submit">Buscar</button>
  </form>

  <!-- Resultados -->
  <% if (query) { %>
    <p>
      <% if (total> 0) { %>
        Se encontraron <strong>
          <%= total %>
        </strong> resultado(s) para "<strong>
          <%= query %>
        </strong>":
        <% } else { %>
          No se encontraron resultados para "<strong>
            <%= query %>
          </strong>".
          <% } %>
    </p>
    <% } %>

      <% results.forEach(doc=> { %>
        <div class="result">
          <h3>
            <%= doc.title %>
          </h3>
          <p class="meta">
            📁 <%= doc.category %> &nbsp;|&nbsp;
              ✍️ <%= doc.author %> &nbsp;|&nbsp;
                📅 <%= doc.date %>
          </p>
        </div>
        <% }) %>

          <% if (query && total===0) { %>
            <p class="empty">Intenta con otros términos de búsqueda.</p>
            <% } %>

              <script>
                document.addEventListener("DOMContentLoaded", () => {
                  const inputValue = document.getElementsByTagName("input").value;
                  const resultValue = document.getElementsByTagName("h3").value;

                  console.log("Query: ", inputValue);
                  console.log("Result:", resultValue);
                });
              </script>
</body>

</html>